# LinguaMedica RW — Environment Variables
# Copy this file to .env for local development, or set these in your hosting provider.

# Required — Flask session security
SECRET_KEY=your-secret-key-here

# Required — Admin login credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password-here

# Optional — Database URL (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional — Port (Railway sets this automatically)
# PORT=5000
